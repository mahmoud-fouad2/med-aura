# ──────────────────────────────────────────────────────────────────────────
# Med Aura — environment template. Copy to `.env.local` and fill in.
# NEVER commit real secrets. `.env*.local` is git-ignored.
# ──────────────────────────────────────────────────────────────────────────

# Node environment: development | test | production
NODE_ENV=development

# Create demo accounts/providers when seeding (DEVELOPMENT ONLY).
# Never set this to true in production. Default: demo data is NOT created.
ENABLE_DEMO_DATA=false

# Optional monitoring webhook — receives sanitized error payloads (no SQL/PII).
MONITORING_WEBHOOK_URL=

# ── Core (required to run) ────────────────────────────────────────────────
# Postgres connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medaura

# Better Auth secret (>= 16 chars). Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# Public base URLs. In dev, http://localhost:3000 is fine.
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# 64 hex chars (32 bytes) — encrypts sensitive fields at rest (e.g. license #).
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Storage: Cloudflare R2 (S3-compatible) ────────────────────────────────
# Leave blank to disable uploads (the UI will say storage is not configured).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional public base URL for PUBLIC assets only (logos, gallery). NEVER for
# private medical files — those always use short-lived signed URLs.
R2_PUBLIC_BASE_URL=

# ── Payments: Stripe (test mode) ──────────────────────────────────────────
# Leave blank to disable payments (booking will show "payments not configured").
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Email (transactional) ─────────────────────────────────────────────────
EMAIL_FROM="Med Aura <no-reply@example.com>"
RESEND_API_KEY=

# ── Video consultation provider (optional) ────────────────────────────────
VIDEO_PROVIDER_API_KEY=
VIDEO_PROVIDER_API_SECRET=

# ── reCAPTCHA (optional; enforced on public forms when set) ───────────────
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
