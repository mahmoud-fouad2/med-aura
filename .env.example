# ──────────────────────────────────────────────────────────────────────────
# Med Aura — environment template. Copy to `.env.local` and fill in.
# NEVER commit real secrets. `.env*.local` is git-ignored.
#
# This file lists ONLY variables that are actually read by the code. Each entry
# notes: [required|optional] · [server-only] · and whether a missing value
# blocks startup or only disables one feature.
# All variables are SERVER-ONLY (there are currently no NEXT_PUBLIC_* vars).
# ──────────────────────────────────────────────────────────────────────────

# ── Required for application startup ───────────────────────────────────────
# NODE_ENV: development | test | production.
# Next.js sets this automatically (dev/build/start); only set it for scripts.
# Optional locally · read across the app (e.g. lib/env.ts, lib/db, lib/crypto).
NODE_ENV=development

# Public base URL of the app — used for links, redirects and Better Auth.
# Required in production (falls back to http://localhost:3000 in dev).
# Read by lib/env.ts (appUrl) and lib/auth.ts. Missing in prod → wrong links.
APP_URL=http://localhost:3000
# Better Auth base URL. If unset, appUrl() is used. Read by lib/env.ts.
BETTER_AUTH_URL=http://localhost:3000

# ── Required for database ──────────────────────────────────────────────────
# PostgreSQL connection string. REQUIRED · server-only.
# Read by lib/db/index.ts, drizzle.config.ts, scripts/*, lib/db/query.ts.
# Missing → BLOCKS startup in production; in dev the app runs but every
# database-backed page shows an honest "temporarily unavailable" state.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medaura

# ── Required for authentication ────────────────────────────────────────────
# Better Auth signing secret (>= 16 chars). REQUIRED · server-only.
# Read by lib/auth.ts. Missing → BLOCKS startup in production.
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# AES-256-GCM key for encrypting sensitive fields at rest (e.g. license #).
# REQUIRED in production · server-only. Read by lib/crypto.ts.
# 64 hex chars (32 bytes). In dev a clearly-warned insecure key is derived if
# unset; in production a missing key BLOCKS startup.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Required for payment (feature) ─────────────────────────────────────────
# Stripe test-mode secret key. OPTIONAL · server-only. Read by lib/payments/stripe.ts.
# Missing → payments are disabled (booking shows "payments not configured");
# does NOT block startup. Checkout is redirect-based (no publishable key used).
STRIPE_SECRET_KEY=
# Stripe webhook signing secret. OPTIONAL · server-only. Read by lib/payments/stripe.ts
# and app/api/webhooks/stripe/route.ts. Without it, webhook events are rejected,
# so payments can be started but never confirmed.
STRIPE_WEBHOOK_SECRET=

# ── Required for storage (feature) ─────────────────────────────────────────
# Cloudflare R2 (S3-compatible). OPTIONAL · server-only. Read by lib/storage/r2.ts.
# All four are needed to enable uploads; missing → uploads disabled (the UI says
# storage is not configured). Private medical files always use signed URLs.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for PUBLIC assets ONLY (never private medical files).
# OPTIONAL · read by lib/storage/r2.ts (getPublicUrl) and next.config.mjs
# (image remotePatterns). Missing → getPublicUrl returns null.
R2_PUBLIC_BASE_URL=

# ── Required for email (feature) ───────────────────────────────────────────
# Resend transactional email. OPTIONAL · server-only. Read by lib/email.ts.
# Both are needed to actually send; missing → emails are logged, not sent
# (verification/reset flows still work in dev). Does NOT block startup.
EMAIL_FROM="Med Aura <no-reply@example.com>"
RESEND_API_KEY=

# ── Optional integrations ──────────────────────────────────────────────────
# reCAPTCHA server-side verification for the contact form. OPTIONAL · server-only.
# Read by lib/security/recaptcha.ts. Missing → verification is skipped (fallback).
# NOTE: the client token widget is not implemented yet, so this is not enforced
# end-to-end until a site-key widget is added.
RECAPTCHA_SECRET_KEY=

# Video consultations. OPTIONAL · server-only. Read by lib/env.ts + lib/video.
# VIDEO_PROVIDER: "daily" (real, needs VIDEO_PROVIDER_API_KEY from
# https://dashboard.daily.co → Developers) or "mock" (local dev/tests only —
# refused in production). Unset → video stays honestly disabled: no join
# buttons anywhere, and /admin/system-health shows "needs setup".
VIDEO_PROVIDER=
VIDEO_PROVIDER_API_KEY=
VIDEO_PROVIDER_API_SECRET=
# Optional webhook signature secret (reserved for provider callbacks).
VIDEO_WEBHOOK_SECRET=
# Join window: how early patients/doctors may enter, and the grace period
# after the scheduled end. Defaults: 10 before / 30 after.
VIDEO_JOIN_WINDOW_BEFORE_MINUTES=10
VIDEO_JOIN_WINDOW_AFTER_MINUTES=30

# Monitoring webhook — receives sanitized error payloads (no SQL/PII).
# OPTIONAL · server-only. Read by lib/monitoring.ts. Missing → errors are logged only.
MONITORING_WEBHOOK_URL=

# ── Development / test only ────────────────────────────────────────────────
# Create demo accounts/providers when seeding. Read by scripts/seed*.ts,
# scripts/check-database.ts, lib/env.ts. MUST stay false/unset in production
# (production startup refuses to boot if this is "true"). Default: not created.
ENABLE_DEMO_DATA=false

# ── Deployment one-off scripts (not read by the app itself) ────────────────
# Consumed ONLY by `pnpm run db:bootstrap-admin` (scripts/bootstrap-admin.ts) to
# create/promote exactly one real Super Admin — safe to run in production
# because YOU supply the real credentials (never a fixed demo password).
# Unset by default; only needed the moment you run that script.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=
# Set to "true" only if you intentionally want to mint an ADDITIONAL admin
# when one already exists (default refuses, to avoid accidental duplicates).
BOOTSTRAP_ADMIN_FORCE=

# Disables Next.js's anonymous CLI telemetry ping. Recommended in production —
# see docs/deployment/render.md "Known issues observed on first deploy" for why.
NEXT_TELEMETRY_DISABLED=1

# ── Notification adapters (all optional) ───────────────────────────────────
# When these are unset, the matching channel in the user's notification-
# preferences UI is rendered as "not configured on the platform" and enabling
# it is rejected server-side — no silent no-op sends.
#
# SMS provider (Twilio-style). If you use a different provider, wire it in
# lib/notifications/sms.ts and keep the env-var names below.
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_API_SECRET=
SMS_PROVIDER_FROM=
#
# WhatsApp Business Cloud API (Meta). Required to send template messages.
WHATSAPP_PROVIDER_ACCESS_TOKEN=
WHATSAPP_PROVIDER_PHONE_NUMBER_ID=
WHATSAPP_PROVIDER_BUSINESS_ACCOUNT_ID=
