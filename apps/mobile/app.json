{
  "expo": {
    "name": "Med Aura",
    "slug": "med-aura",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "scheme": "medaura",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFFCF7",
    "ios": {
      "bundleIdentifier": "com.medaura.app",
      "supportsTablet": false,
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "NSCameraUsageDescription": "يستخدم Med Aura الكاميرا أثناء الاستشارة المرئية مع طبيبك.",
        "NSMicrophoneUsageDescription": "يستخدم Med Aura المايكروفون أثناء الاستشارة المرئية مع طبيبك."
      }
    },
    "android": {
      "package": "com.medaura.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#FCFAFB",
        "foregroundImage": "./assets/brand/adaptive-foreground.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "extra": {
      "supportsRTL": true,
      "forcesRTL": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-web-browser",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "يستخدم Med Aura بصمة الوجه لفتح التطبيق بأمان."
        }
      ],
      [
        "@daily-co/config-plugin-rn-daily-js",
        {
          "enableCamera": true,
          "enableMicrophone": true,
          "enableScreenShare": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#4A1D96",
          "image": "./assets/brand/splash-logo.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
